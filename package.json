{
  "name": "backend-fiadito",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "test": "jest",
    "migration:generate": "typeorm-ts-node-commonjs -d typeorm.datasource.ts migration:generate src/database/migrations/AutoMigration",
    "migration:create": "typeorm-ts-node-commonjs -d typeorm.datasource.ts migration:create src/database/migrations/ManualMigration",
    "migration:run": "ts-node src/database/run-migrations.ts",
    "migration:revert": "typeorm-ts-node-commonjs -d typeorm.datasource.ts migration:revert"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/typeorm": "^10.0.2",
    "argon2": "^0.41.1",
    "basic-ftp": "^5.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ssh2-sftp-client": "^12.1.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/ssh2-sftp-client": "^9.0.6",
    "eslint": "^9.10.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.56.1"
  }
}
